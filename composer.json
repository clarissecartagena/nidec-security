{
    "name": "nidec/security-management-system",
    "description": "NIDEC Security Management System with optimized MVC architecture",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Controllers\\": "app/controllers/",
            "App\\Models\\": "app/models/",
            "App\\Services\\": "app/services/",
            "App\\Core\\": "app/core/",
            "App\\ApiClients\\": "app/api_clients/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
