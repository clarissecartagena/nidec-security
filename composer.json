{
    "name": "nidec/security-management-system",
    "description": "NIDEC Security Management System with optimized MVC architecture",
    "type": "project",
    "require": {
        "php": ">=8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\Controllers\\": "app/controllers/",
            "App\\Core\\": "app/core/"
        },
        "classmap": [
            "app/models/",
            "app/services/",
            "app/api_clients/"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
